# Database
DATABASE_URL="postgresql://username:password@localhost:5432/bemoremodest"

# App Configuration
APP_BASE_URL="https://app.bemoremodest.com"
SMARTLINK_DOMAIN="https://go.bemoremodest.com"

# Email
POSTMARK_TOKEN="your_postmark_token"
KLAVIYO_API_KEY="your_klaviyo_api_key"

# SMS
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_MESSAGING_SID="your_twilio_messaging_sid"

# Meta (Facebook/Instagram)
META_APP_ID="your_meta_app_id"
META_APP_SECRET="your_meta_app_secret"
META_PAGE_ID="your_meta_page_id"
META_ACCESS_TOKEN="your_meta_access_token"
META_PIXEL_ID="your_meta_pixel_id"

# SoundCloud
SC_CLIENT_ID="your_soundcloud_client_id"
SC_CLIENT_SECRET="your_soundcloud_client_secret"
SC_REDIRECT_URI="${APP_BASE_URL}/settings/soundcloud/callback"

# Spotify
SPOTIFY_CLIENT_ID="your_spotify_client_id"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret"

# Apple Music
APPLE_TEAM_ID="your_apple_team_id"
APPLE_KEY_ID="your_apple_key_id"
APPLE_PRIVATE_KEY="your_apple_private_key"

# Shopify
SHOPIFY_STORE_DOMAIN="your_store.myshopify.com"
SHOPIFY_ACCESS_TOKEN="your_shopify_access_token"

# Security
JWT_SECRET="your_super_long_random_jwt_secret"
HASH_SALT="your_super_long_random_hash_salt"